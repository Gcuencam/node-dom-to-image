{
  "name": "node-dom-to-image",
  "version": "2.0.0",
  "description": "Turn any DOM node into an SVG, canvas, PNG/JPEG, Blob or downloadable image, in the browser",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "dom",
    "image",
    "screenshot",
    "canvas",
    "svg",
    "png",
    "download"
  ],
  "author": "Gabriel Cuenca Moncín",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gcuencam/node-dom-to-image.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
